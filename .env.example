# Anthropic API Key — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Tavily Search API Key — https://app.tavily.com/
TAVILY_API_KEY=tvly-xxxxx

# SMS verification — https://www.smsbao.com/openapi/213.html
# SMS_DEV_MODE=auto means: use real SMS when SMSBAO_USERNAME + SMSBAO_API_KEY exist,
# otherwise print the code in the backend console for local development.
SMS_DEV_MODE=auto
SMSBAO_USERNAME=
SMSBAO_API_KEY=
SMSBAO_GOODS_ID=
SMS_CODE_TEMPLATE=【阿川AI】您的验证码是{code}，{minutes}分钟内有效。如非本人操作，请忽略。
SMS_CODE_EXPIRE_SECONDS=300
SMS_RESEND_INTERVAL_SECONDS=60
SMS_DAILY_LIMIT_PER_PHONE=10
SMS_HOURLY_LIMIT_PER_IP=30
SMS_MAX_VERIFY_ATTEMPTS=5
SMS_REQUEST_TIMEOUT_SECONDS=10

# Agent model (default: claude-opus-4-6)
AGENT_MODEL=claude-opus-4-6

# Max tokens for each model response
AGENT_MAX_TOKENS=4096

# Per-tool call timeout in seconds
AGENT_TOOL_TIMEOUT=30

# Docmee / 文多多 AiPPT — https://open.docmee.cn/docs-v2
DOCMEE_API_KEY=
DOCMEE_BASE_URL=https://open.docmee.cn
DOCMEE_TOKEN_HOURS=2
DOCMEE_TEMPLATE_SIZE=1

# Payments are closed by default. Set to true only when you want to reopen sales.
PAYMENTS_ENABLED=false

# Server bind address and port
HOST=0.0.0.0
PORT=8000

# Production process settings. For an 8C16G single-server deployment, start with
# 4 Uvicorn workers. Each worker has its own database pool below.
UVICORN_HOST=127.0.0.1
UVICORN_PORT=8000
UVICORN_WORKERS=4
UVICORN_LIMIT_CONCURRENCY=200
UVICORN_BACKLOG=2048
UVICORN_TIMEOUT_KEEP_ALIVE=30

# PostgreSQL. With 4 workers, the default pool below can open up to 60 DB
# connections in total: workers * (DB_POOL_SIZE + DB_MAX_OVERFLOW).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_agent_platform
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Default admin phone numbers.
# On login, these phones are automatically promoted to users.is_admin=true.
# Separate multiple phones with commas. FIRST_ADMIN_PHONE is also supported for single-admin deployments.
DEFAULT_ADMIN_PHONES=13260018535

# Tencent Cloud COS uploads for practice articles / course media.
# Production configuration should be saved in the admin UI; these are local fallback defaults.
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=your-bucket-1250000000
# Optional custom CDN/domain. Leave empty to use the COS default public URL.
COS_PUBLIC_BASE_URL=
PRACTICE_IMAGE_MAX_MB=10
PRACTICE_VIDEO_MAX_MB=20480
PRACTICE_DOCUMENT_MAX_MB=200

# Feishu document import.
# Production configuration should be saved in the admin UI; these are local fallback defaults.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
